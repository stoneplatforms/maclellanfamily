# Copy to terraform.tfvars and fill in secrets (terraform.tfvars is gitignored)
#
# S3 bucket must already exist in this region.
# MediaConvert: AWS Console → MediaConvert → Account → copy API endpoint;
#   IAM role for MediaConvert must trust mediaconvert.amazonaws.com and allow S3 read/write on the bucket.

aws_region   = "us-east-1"
project      = "maclellanfamily"
bucket_name  = "www.maclellanfamily.com"

dropbox_client_id     = "35m29zvt89kyau0"
dropbox_client_secret = "8tc4oewi4qkq226"
dropbox_refresh_token = "iku0qhGJx5MAAAAAAAAAAZFGGe7UdElwMdgofxDq-wMEwIk5LG0p_BfK-lNuzbcU"

# Example shape — use your account’s real endpoint and role ARN
mediaconvert_endpoint = "https://mediaconvert.us-east-1.amazonaws.com"
mediaconvert_role_arn = "arn:aws:iam::509521484205:user/MediaConvertAccessRole"
